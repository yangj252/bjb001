/*
  Content-Security-Policy: default-src 'self'; base-uri 'none'; connect-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self'; manifest-src 'self'; object-src 'none'; script-src 'self'; style-src 'self'; worker-src 'self'
  Cache-Control: public, max-age=0, must-revalidate
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Permissions-Policy: camera=(), geolocation=(), microphone=(), payment=(), usb=()
  Referrer-Policy: no-referrer
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

/index.html
  Cache-Control: no-cache

/share.html
  ! Cache-Control
  Cache-Control: no-store

/share
  ! Cache-Control
  Cache-Control: no-store

/app.js
  Cache-Control: public, max-age=0, must-revalidate

/share.js
  Cache-Control: public, max-age=0, must-revalidate

/share-crypto.js
  Cache-Control: public, max-age=0, must-revalidate

/styles.css
  Cache-Control: public, max-age=0, must-revalidate

/share.css
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

/app-icon.svg
  Cache-Control: public, max-age=604800
